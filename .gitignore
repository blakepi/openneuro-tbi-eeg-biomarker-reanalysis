*.set
*.fdt
*.fif
*.edf
*.bdf
*.vhdr
*.eeg
*.vmrk
*.mat
*.xlsx

# Python environment / caches
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Credentials / secrets (never commit)
.env
*.key
*.pem
*token*
*credentials*
.netrc

